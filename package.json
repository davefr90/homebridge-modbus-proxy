{
  "name": "homebridge-modbus-proxy",
  "displayName": "Modbus Proxy",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "A scalable Modbus TCP proxy plugin for Homebridge with multi-client support, request queueing, caching and statistics.",
  "author": "David Friedrich",
  "license": "MIT",
  "homepage": "https://github.com/davefr90/homebridge-modbus-proxy#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/davefr90/homebridge-modbus-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/davefr90/homebridge-modbus-proxy/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "modbus",
    "modbus-tcp",
    "modbus-proxy",
    "industrial-automation",
    "building-automation"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": "^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "clean": "rimraf ./dist ./coverage",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build",
    "watch": "npm run build && npm link && nodemon"
  },
  "dependencies": {
    "homebridge-lib": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.3.0",
    "homebridge": "^2.0.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.10"
  }
}
